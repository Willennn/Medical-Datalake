# ------------------------------------------------------------------
# Copie ce fichier en ".env" (sans le .example) et garde ces valeurs
# pour commencer. Le .env contient les mots de passe : il ne doit
# JAMAIS être envoyé sur GitHub (il est déjà dans le .gitignore).
# ------------------------------------------------------------------

# --- MinIO (entrepôt de fichiers) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000

# --- PostgreSQL (base de données) ---
POSTGRES_USER=datalake
POSTGRES_PASSWORD=datalake
POSTGRES_DB=datalake
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Noms des buckets (dossiers de stockage) ---
BUCKET_RAW=raw
BUCKET_STAGING=staging

# --- Source API : OpenAQ (qualité de l'air) ---
# Récupère ta clé GRATUITE sur : https://explore.openaq.org/register
# (compte -> settings -> API key), puis colle-la ci-dessous.
OPENAQ_API_KEY=
